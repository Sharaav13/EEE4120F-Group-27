    for d = 1:num_images
        plot(2:max_workers, efficiency_results{d}, 'Marker', 'o', 'MarkerSize', 8, 'LineStyle', '-', 'LineWidth', 2);
        hold on;
    end
    hold off;
    xlabel('Number of cores');
    ylabel('Efficiency (%)');
    title('Efficiency vs Number of cores');
    legend(image_names,'Location','southwest');
    grid on;
    saveas(gcf, "Efficiency_vs_Number_of_cores.png");
    
    save('results.mat', 'time_serial_results', 'time_parallel_results', 'speedup_results', 'efficiency_results');
end

run_analysisf();